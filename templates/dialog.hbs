<div class="ai-scene-generator-wrapper">

  {{!-- Prompt --}}
  <div class="section">
    <label class="section-label">
      <i class="fas fa-pen-nib"></i>
      {{localize "AISCENEGEN.PromptLabel"}}
    </label>
    <textarea class="prompt-input" rows="4"
      placeholder="{{localize "AISCENEGEN.PromptPlaceholder"}}"></textarea>
  </div>

  {{!-- Style Picker --}}
  <div class="section">
    <label class="section-label">
      <i class="fas fa-paint-brush"></i>
      {{localize "AISCENEGEN.StyleLabel"}}
    </label>
    <div class="style-grid">
      {{#each styles}}
      <button class="style-btn {{#if active}}active{{/if}}"
        data-style="{{id}}" title="{{label}}" type="button">
        <i class="fas {{icon}}"></i>
        <span>{{label}}</span>
      </button>
      {{/each}}
    </div>
  </div>

  {{!-- Scene Name --}}
  <div class="section">
    <label class="section-label">
      <i class="fas fa-map"></i>
      {{localize "AISCENEGEN.SceneNameLabel"}}
    </label>
    <input type="text" class="scene-name-input"
      placeholder="{{localize "AISCENEGEN.SceneNamePlaceholder"}}" />
  </div>

  {{!-- Generate --}}
  <div class="section actions-section">
    <button class="btn-generate" type="button">
      <i class="fas fa-wand-magic-sparkles"></i>
      <span>{{localize "AISCENEGEN.Generate"}}</span>
    </button>
    <span class="generate-status"></span>
    <span class="spinner" style="display:none;">
      <i class="fas fa-spinner fa-spin"></i>
    </span>
  </div>

  {{!-- Preview --}}
  <div class="section preview-section" style="display:none;">
    <label class="section-label">
      <i class="fas fa-eye"></i>
      {{localize "AISCENEGEN.PreviewLabel"}}
    </label>
    <div class="preview-container">
      <img class="preview-img" src="" alt="Preview" />
    </div>

    {{!-- Full prompt display --}}
    <details class="prompt-details">
      <summary>{{localize "AISCENEGEN.FullPromptLabel"}}</summary>
      <p class="full-prompt-display"></p>
    </details>

    {{!-- Change request field --}}
    <div class="section change-section">
      <label class="section-label">
        <i class="fas fa-sliders"></i>
        {{localize "AISCENEGEN.ChangeLabel"}}
      </label>
      <textarea class="change-input" rows="2"
        placeholder="{{localize "AISCENEGEN.ChangePlaceholder"}}"></textarea>
    </div>

    {{!-- Preview actions --}}
    <div class="preview-actions">
      <button class="btn-regenerate" type="button" disabled>
        <i class="fas fa-rotate"></i>
        <span>{{localize "AISCENEGEN.Regenerate"}}</span>
      </button>
      <button class="btn-create-scene" type="button" disabled>
        <i class="fas fa-plus"></i>
        <span>{{localize "AISCENEGEN.CreateScene"}}</span>
      </button>
    </div>
  </div>

</div>
